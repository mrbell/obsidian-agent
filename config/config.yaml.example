paths:
  vault: ~/ObsidianVault               # real vault path; read-only to jobs
  outbox: ~/.local/share/obsidian-agent/outbox
  state_dir: ~/.local/share/obsidian-agent
  bot_inbox_rel: BotInbox              # relative path inside vault; must not be absolute

cache:
  duckdb_path: ~/.local/share/obsidian-agent/index.duckdb

semantic:
  model: all-MiniLM-L6-v2
  max_notes_per_run: 50             # remove or set to null once initial index is built

indexing:
  schedule: "0 3 * * *"            # structural index — nightly at 03:00
  semantic_schedule: "5 3 * * *"   # semantic index — nightly at 03:05
  exclude_paths:                    # top-level vault folders to skip entirely
    - Archive
    - BotInbox

delivery:
  email:
    smtp_host: smtp.gmail.com
    smtp_port: 587
    username: you@gmail.com
    password_env: OBSIDIAN_AGENT_SMTP_PASSWORD   # export this in your shell or systemd unit
    from_address: you@gmail.com
    to_address: you@gmail.com

agent:
  backend: claude                  # claude or codex
  command: claude
  args: ["--print", "--output-format", "json", "--no-session-persistence"]
  timeout_seconds: 300
  work_dir: ~/.local/share/obsidian-agent/agent_workdir
  # Codex example:
  # backend: codex
  # command: codex
  # args: ["exec", "--sandbox", "read-only", "--ephemeral"]

jobs:
  task_notification:
    enabled: true
    schedule: "0 7 * * *"             # informational; enforced by cron/systemd
    lookahead_days: 3
    include_overdue: true
    notify_if_empty: false
    also_write_vault_artifact: false

  research_digest:
    enabled: true
    schedule: "0 18 * * 0"            # Sunday 18:00
    lookback_days: 7
    topics:
      - "agentic coding"              # plain string — works as before
      - name: "Rust"                  # structured — name only, behaves like plain string
      - name: "machine learning"      # structured — with optional fields
        description: "focus on interpretability and alignment"
        feeds:
          - "https://arxiv.org/rss/cs.LG"
          - "https://arxiv.org/rss/cs.AI"
        sources:
          - "distill.pub"          # web search hint for sources without feeds
    also_notify: true

  vault_connections_report:
    enabled: true
    schedule: "0 9 * * 1"             # Monday 09:00
    lookback_recent_days: 14          # notes modified in this window = "recent"
    lookback_old_days: 30             # only surface notes not touched in this many days
    max_connections: 5                # max items to include in the report
    also_notify: true

  vault_hygiene_report:
    enabled: true
    schedule: "0 10 1,15 * *"         # 1st and 15th of the month
    also_notify: true
